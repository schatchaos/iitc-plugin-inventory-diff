INVDIFF_PORT=3000
INVDIFF_REDIS_URL=redis://localhost:6379
INVDIFF_CORS_ORIGIN=https://intel.ingress.com
INVDIFF_MAX_SNAPSHOTS=50

# TLS (optional — omit for plain HTTP behind a reverse proxy)
# INVDIFF_TLS_CERT=/etc/letsencrypt/live/your.hostname/fullchain.pem
# INVDIFF_TLS_KEY=/etc/letsencrypt/live/your.hostname/privkey.pem
